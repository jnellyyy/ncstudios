{
  "manifestVersion": 5,
  "id": "uk.ncstudios.premiere-edit-agent",
  "name": "NC Edit Agent",
  "version": "0.1.0",
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "25.6.0"
  },
  "requiredPermissions": {
    "localFileSystem": "request"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "nc-edit-agent-panel",
      "label": {
        "default": "NC Edit Agent"
      },
      "minimumSize": {
        "width": 330,
        "height": 520
      },
      "preferredDockedSize": {
        "width": 390,
        "height": 760
      },
      "preferredFloatingSize": {
        "width": 430,
        "height": 820
      },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "icons/panel.svg",
          "theme": ["all"],
          "scale": [1]
        }
      ]
    }
  ],
  "icons": [
    {
      "width": 24,
      "height": 24,
      "path": "icons/plugin.svg",
      "theme": ["all"],
      "scale": [1]
    }
  ]
}
